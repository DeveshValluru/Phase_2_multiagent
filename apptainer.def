Bootstrap: docker
From: vault.habana.ai/gaudi-docker/1.17.0/ubuntu22.04/habanalabs/pytorch-installer-2.3.1:latest

%post
    apt-get update && apt-get install -y --no-install-recommends \
        git curl ca-certificates build-essential \
        && rm -rf /var/lib/apt/lists/*

    pip install --upgrade pip

    # vLLM for Gaudi (HPU). If your Sol cluster provides a pinned vllm-hpu wheel,
    # replace this with that wheel. Otherwise the habana fork is the standard.
    pip install --no-cache-dir \
        vllm==0.6.3 \
        "optimum-habana>=1.13.0" \
        transformers==4.44.2 \
        accelerate==0.33.0 \
        sentence-transformers==2.7.0 \
        rouge-score==0.1.2 \
        bert-score==0.3.13 \
        pyyaml==6.0.1 \
        pandas==2.2.2 \
        tqdm==4.66.4 \
        openai==1.40.0 \
        httpx==0.27.0 \
        tenacity==8.5.0 \
        scikit-learn==1.5.1

%environment
    export PT_HPU_LAZY_MODE=1
    export HABANA_VISIBLE_DEVICES=all
    export VLLM_GRAPH_RESERVED_MEM=0.1

%labels
    Project phase2-multiagent
    Maintainer CSE598-Spring2026
